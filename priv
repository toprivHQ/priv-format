#!/usr/bin/env python3
"""
priv - Encrypt and decrypt .priv files from the command line.

Part of the .priv open encrypted file format by topriv.
https://github.com/toprivHQ/priv-format

Usage:
    priv encrypt file1.pdf file2.jpg -o bundle.priv
    priv decrypt bundle.priv -o ./output/
    priv info bundle.priv
"""

import argparse
import getpass
import hashlib
import os
import struct
import sys
from pathlib import Path

try:
    from cryptography.hazmat.primitives.ciphers.aead import AESGCM
    from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
    from cryptography.hazmat.primitives import hashes
except ImportError:
    print("Error: 'cryptography' package required. Install with:")
    print("  pip install cryptography")
    sys.exit(1)

MAGIC = b"PRIV"
VERSION = 1
HEADER_SIZE = 54
PBKDF2_ITERATIONS = 600_000


def derive_key(password: str, salt: bytes) -> bytes:
    kdf = PBKDF2HMAC(
        algorithm=hashes.SHA256(),
        length=32,
        salt=salt,
        iterations=PBKDF2_ITERATIONS,
    )
    return kdf.derive(password.encode("utf-8"))


def build_payload(files: list[tuple[str, bytes]]) -> bytes:
    parts = []
    parts.append(struct.pack(">I", len(files)))
    for name, data in files:
        name_bytes = name.encode("utf-8")
        parts.append(struct.pack(">H", len(name_bytes)))
        parts.append(name_bytes)
        parts.append(struct.pack(">I", len(data)))
        parts.append(data)
    return b"".join(parts)


def parse_payload(data: bytes) -> list[tuple[str, bytes]]:
    offset = 0
    (file_count,) = struct.unpack_from(">I", data, offset)
    offset += 4
    files = []
    for _ in range(file_count):
        (name_len,) = struct.unpack_from(">H", data, offset)
        offset += 2
        name = data[offset : offset + name_len].decode("utf-8")
        offset += name_len
        (data_len,) = struct.unpack_from(">I", data, offset)
        offset += 4
        file_data = data[offset : offset + data_len]
        offset += data_len
        files.append((name, file_data))
    return files


def encrypt_files(file_paths: list[str], password: str, output: str, expiry: int = 0, strip_metadata: bool = True):
    files = []
    for path_str in file_paths:
        p = Path(path_str)
        if not p.exists():
            print(f"Error: {path_str} not found", file=sys.stderr)
            sys.exit(1)
        if p.is_dir():
            for child in sorted(p.rglob("*")):
                if child.is_file():
                    rel = str(child.relative_to(p.parent))
                    files.append((rel, child.read_bytes()))
        else:
            files.append((p.name, p.read_bytes()))

    if not files:
        print("Error: no files to encrypt", file=sys.stderr)
        sys.exit(1)

    salt = os.urandom(32)
    iv = os.urandom(12)
    key = derive_key(password, salt)
    payload = build_payload(files)

    aesgcm = AESGCM(key)
    ciphertext = aesgcm.encrypt(iv, payload, None)

    flags = 0
    if strip_metadata:
        flags |= 0x02
    if expiry > 0:
        flags |= 0x01

    header = bytearray(HEADER_SIZE)
    header[0:4] = MAGIC
    header[4] = VERSION
    header[5] = flags
    struct.pack_into(">I", header, 6, expiry)
    header[10:42] = salt
    header[42:54] = iv

    out_path = output or "output.priv"
    with open(out_path, "wb") as f:
        f.write(header)
        f.write(ciphertext)

    total_size = len(files)
    raw_size = sum(len(d) for _, d in files)
    enc_size = HEADER_SIZE + len(ciphertext)
    print(f"\033[32m✓\033[0m Encrypted {total_size} file(s) ({format_size(raw_size)}) → {out_path} ({format_size(enc_size)})")


def decrypt_file(priv_path: str, password: str, output: str):
    p = Path(priv_path)
    if not p.exists():
        print(f"Error: {priv_path} not found", file=sys.stderr)
        sys.exit(1)

    data = p.read_bytes()
    if len(data) < HEADER_SIZE:
        print("Error: file too small to be a valid .priv file", file=sys.stderr)
        sys.exit(1)

    if data[0:4] != MAGIC:
        print("Error: not a valid .priv file (bad magic bytes)", file=sys.stderr)
        sys.exit(1)

    version = data[4]
    if version != 1:
        print(f"Error: unsupported .priv version {version}", file=sys.stderr)
        sys.exit(1)

    flags = data[5]
    (expiry_ts,) = struct.unpack_from(">I", data, 6)

    if (flags & 0x01) and expiry_ts > 0:
        import time
        if time.time() > expiry_ts:
            from datetime import datetime, timezone
            exp_date = datetime.fromtimestamp(expiry_ts, tz=timezone.utc).isoformat()
            print(f"Error: this .priv file expired on {exp_date}", file=sys.stderr)
            sys.exit(1)

    salt = data[10:42]
    iv = data[42:54]
    ciphertext = data[HEADER_SIZE:]

    key = derive_key(password, salt)
    aesgcm = AESGCM(key)

    try:
        plaintext = aesgcm.decrypt(iv, ciphertext, None)
    except Exception:
        print("Error: wrong password or corrupted file", file=sys.stderr)
        sys.exit(1)

    files = parse_payload(plaintext)
    out_dir = Path(output or ".")
    out_dir.mkdir(parents=True, exist_ok=True)

    for name, file_data in files:
        out_file = out_dir / name
        out_file.parent.mkdir(parents=True, exist_ok=True)
        out_file.write_bytes(file_data)
        print(f"  {name} ({format_size(len(file_data))})")

    print(f"\n\033[32m✓\033[0m Decrypted {len(files)} file(s) to {out_dir}/")


def info_file(priv_path: str):
    p = Path(priv_path)
    if not p.exists():
        print(f"Error: {priv_path} not found", file=sys.stderr)
        sys.exit(1)

    data = p.read_bytes()
    if len(data) < HEADER_SIZE or data[0:4] != MAGIC:
        print("Error: not a valid .priv file", file=sys.stderr)
        sys.exit(1)

    version = data[4]
    flags = data[5]
    (expiry_ts,) = struct.unpack_from(">I", data, 6)

    print(f"File:              {priv_path}")
    print(f"Size:              {format_size(len(data))}")
    print(f"Format version:    {version}")
    print(f"Metadata stripped:  {'Yes' if flags & 0x02 else 'No'}")

    if flags & 0x01 and expiry_ts > 0:
        from datetime import datetime, timezone
        exp = datetime.fromtimestamp(expiry_ts, tz=timezone.utc)
        import time
        expired = " (EXPIRED)" if time.time() > expiry_ts else ""
        print(f"Expiry:            {exp.strftime('%Y-%m-%d %H:%M UTC')}{expired}")
    else:
        print(f"Expiry:            None")

    print(f"Payload size:      {format_size(len(data) - HEADER_SIZE)}")


def format_size(n: int) -> str:
    if n < 1024:
        return f"{n} B"
    if n < 1024 * 1024:
        return f"{n / 1024:.1f} KB"
    if n < 1024 * 1024 * 1024:
        return f"{n / (1024 * 1024):.1f} MB"
    return f"{n / (1024 * 1024 * 1024):.1f} GB"


def ask_password(confirm: bool = False) -> str:
    pw = getpass.getpass("Password: ")
    if not pw:
        print("Error: password cannot be empty", file=sys.stderr)
        sys.exit(1)
    if confirm:
        pw2 = getpass.getpass("Confirm password: ")
        if pw != pw2:
            print("Error: passwords do not match", file=sys.stderr)
            sys.exit(1)
    return pw


BANNER = """
\033[1;31m ██████╗ ██████╗ ██╗██╗   ██╗
 ██╔══██╗██╔══██╗██║██║   ██║
 ██████╔╝██████╔╝██║██║   ██║
 ██╔═══╝ ██╔══██╗██║╚██╗ ██╔╝
 ██║     ██║  ██║██║ ╚████╔╝
 ╚═╝     ╚═╝  ╚═╝╚═╝  ╚═══╝\033[0m
 \033[2mby topriv · https://topriv.com\033[0m
"""

VERSION_STR = "priv 1.0.0 · .priv format v1 · by topriv (https://topriv.com)"


def main():
    parser = argparse.ArgumentParser(
        prog="priv",
        description="Encrypt and decrypt .priv files - an open encrypted container format by topriv.",
        epilog="Built by topriv — https://topriv.com | https://github.com/toprivHQ/priv-format",
    )
    parser.add_argument("-v", "--version", action="version", version=VERSION_STR)
    sub = parser.add_subparsers(dest="command", required=True)

    # encrypt
    enc = sub.add_parser("encrypt", aliases=["e"], help="Encrypt files into a .priv container")
    enc.add_argument("files", nargs="+", help="Files or directories to encrypt")
    enc.add_argument("-o", "--output", default="output.priv", help="Output .priv file (default: output.priv)")
    enc.add_argument("--expiry", type=int, default=0, metavar="TIMESTAMP", help="Unix timestamp for expiry (0 = no expiry)")
    enc.add_argument("--no-strip", action="store_true", help="Do not set the metadata-stripped flag")

    # decrypt
    dec = sub.add_parser("decrypt", aliases=["d"], help="Decrypt a .priv file")
    dec.add_argument("file", help="The .priv file to decrypt")
    dec.add_argument("-o", "--output", default=".", help="Output directory (default: current directory)")

    # info
    inf = sub.add_parser("info", aliases=["i"], help="Show .priv file metadata without decrypting")
    inf.add_argument("file", help="The .priv file to inspect")

    args = parser.parse_args()

    if sys.stdout.isatty():
        print(BANNER)

    if args.command in ("encrypt", "e"):
        pw = ask_password(confirm=True)
        encrypt_files(args.files, pw, args.output, args.expiry, not args.no_strip)

    elif args.command in ("decrypt", "d"):
        pw = ask_password()
        decrypt_file(args.file, pw, args.output)

    elif args.command in ("info", "i"):
        info_file(args.file)


if __name__ == "__main__":
    main()
